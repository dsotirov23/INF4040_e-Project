@model e_Project.Models.User

<h2>Login</h2>

<form asp-action="Login" method="post">
    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email" name="email" class="form-control" placeholder="Email" />
    </div>

    <div class="mb-3">
        <label>Password</label>
        <input asp-for="Password" name="password" type="password" class="form-control" placeholder="Password" />
    </div>

    <button type="submit" class="btn btn-primary">Login</button>
</form>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mt-3">
        @ViewBag.Error
    </div>
}